{% set check_tags = ["permanent", "inherent", "n_a", "not_applicable"] %}
{% set additional_info = rule | get_nested(["platforms", rule.os_type, "enforcement_info", "fix", "additional_info"]) %}
{% set check_shell = rule | get_nested(["platforms", rule.os_type, "enforcement_info", "check", "shell"]) %}
{% set fix_shell = rule | get_nested(["platforms", rule.os_type, "enforcement_info", "fix", "shell"]) %}

<h3 id="{{ rule.title | to_anchor_id }}">{{ section_num }}.{{ rule_num }}. {{ rule.title }}</h3>

{% if rule.tags is defined or rule.tags is not none and "supplemental" in rule.tags %}
{{ rule.discussion | include_replace | asciidoc_to_html }}
{% else %}
{{ rule.discussion | asciidoc_to_html }}
{% endif %}

{%- if rule.mechanism == "manual" %}
<div class="admonitionblock note"><table><tr>
<td class="icon"><i class="fa icon-note" title="Note"></i></td>
<td class="content">{% trans %} This rule is marked as manual and may not be able to be automated. It is also excluded in the compliance scan and will not report any results. {% endtrans %}</td>
</tr></table></div>
{% endif -%}

{% if not rule.tags | select('in', check_tags) | list %}
{% if rule.tags is not defined or rule.tags is none or "supplemental" not in rule.tags %}
{% if rule.os_type.lower() in NIX_OS %}
<div class="paragraph"><p>{% trans %}To check the state of the system, run the following command(s){% endtrans %}:</p></div>
<div class="listingblock"><div class="content">
<pre class="rouge highlight nowrap"><code data-lang="zsh">{% if check_shell is not none %}{{ check_shell | e }}{% else %}{{ rule.check | replace("\\\\", "\\") | replace('\\"', '"') | trim | e }}{% endif %}</code></pre>
</div></div>
{% else %}
{% if rule.check is not none %}<div class="paragraph"><p>{{ rule.check }}</p></div>{% endif %}
{% endif %}

{% if rule.os_type.lower() in NIX_OS %}
<div class="paragraph"><p>{% trans %}If the result is not{% endtrans %} <em>{{ rule.result_value }}</em>, {% trans %}this is a finding{% endtrans %}.</p></div>
{% endif %}

<div class="exampleblock">
<div class="content">
<div class="paragraph"><p><strong>{% trans %}Remediation Description{% endtrans %}</strong></p></div>

{% if rule.fix is not none %}
<div class="paragraph"><p>{% trans %}Perform the following to configure the system to meet the requirements{% endtrans %}:</p></div>
{% endif %}

{% if rule.mobileconfig_info is none and rule.fix is not none or fix_shell %}
<div class="paragraph"><p>{% trans %}Run the following command(s){% endtrans %}:</p></div>
<div class="listingblock"><div class="content">
<pre class="rouge highlight nowrap"><code data-lang="zsh">{{ (rule.fix if rule.fix is not none else fix_shell) | e }}</code></pre>
</div></div>

{% elif additional_info is not none %}
{{ additional_info | asciidoc_to_html }}
{% elif rule.mobileconfig_info is not none and fix_shell %}
{% if fix_shell %}
<div class="listingblock"><div class="content">
<pre class="rouge highlight nowrap"><code data-lang="zsh">{{ fix_shell | e }}</code></pre>
</div></div>
{% endif %}

{% if rule.mobileconfig_info %}
<div class="listingblock"><div class="content">
<pre class="rouge highlight nowrap"><code data-lang="xml">{{ rule.mobileconfig_info | mobileconfig_payloads_to_xml | e }}</code></pre>
</div></div>
{% endif %}
{% else %}
{% if rule.os_name == "macos" %}
{{ rule.fix | asciidoc_to_html }}
{% else %}
<div class="paragraph"><p>{% trans %}Deploy a configuration profile containing the following payload.{% endtrans %}</p></div>
<div class="listingblock"><div class="content">
<pre class="rouge highlight nowrap"><code data-lang="xml">{{ rule.mobileconfig_info | mobileconfig_payloads_to_xml | e }}</code></pre>
</div></div>
{% endif %}
{% endif %}
</div>
</div>
{% endif %}

<table class="tableblock frame-all grid-all stretch">
<colgroup>
<col style="width: 15%;">
<col style="width: 85%;">
</colgroup>
<tbody>
<tr>
<th class="tableblock halign-left valign-top"><p class="tableblock">ID</p></th>
<td class="tableblock halign-left valign-top"><div class="content"><div class="paragraph">
<p>{{ rule.rule_id }}{% if rule.severity is not none %}<br />{{ rule.severity }}{% endif %}</p>
</div></div></td>
</tr>
<tr>
<th class="tableblock halign-left valign-top"><p class="tableblock">{% trans %}References{% endtrans %}</p></th>
<td class="tableblock halign-left valign-top"><div class="content"><table class="tableblock frame-none grid-cols stretch">
<colgroup>
<col style="width: 20%;">
<col style="width: 80%;">
</colgroup>
<tbody>
<tr>
<th class="tableblock halign-left valign-top"><p class="tableblock">800-53r5</p></th>
<td class="tableblock halign-left valign-top"><p class="tableblock">{{ rule.references.nist.nist_800_53r5 | group_ulify if rule.references.nist.nist_800_53r5 is not none }}</p></td>
</tr>
{% if "800-171" in baseline.title | upper or show_all_tags %}
<tr>
<th class="tableblock halign-left valign-top"><p class="tableblock">800-171r3</p></th>
<td class="tableblock halign-left valign-top"><p class="tableblock">{{ rule.references.nist.nist_800_171r3 | render_rules if rule.references.nist.nist_800_171r3 is not none }}</p></td>
</tr>
{% endif %}
{% if "STIG" in baseline.title | upper or show_all_tags %}
<tr>
<th class="tableblock halign-left valign-top"><p class="tableblock">DISA STIG(s)</p></th>
<td class="tableblock halign-left valign-top"><p class="tableblock">{{ rule.references.disa.disa_stig | render_rules if rule.references.disa.disa_stig is not none }}</p></td>
</tr>
{% if rule.references.disa.sfr is not none %}
<tr>
<th class="tableblock halign-left valign-top"><p class="tableblock">SFR</p></th>
<td class="tableblock halign-left valign-top"><p class="tableblock">{{ rule.references.disa.sfr | render_rules if rule.references.disa.sfr is not none }}</p></td>
</tr>
{% endif %}
{% endif %}
{% if "CIS" in baseline.title | upper or show_all_tags %}
<tr>
<th class="tableblock halign-left valign-top"><p class="tableblock">CIS Benchmark</p></th>
<td class="tableblock halign-left valign-top"><p class="tableblock">{{ rule.references.cis.benchmark | render_rules if rule.references.cis.benchmark is not none }}</p></td>
</tr>
<tr>
<th class="tableblock halign-left valign-top"><p class="tableblock">CIS Controls V8</p></th>
<td class="tableblock halign-left valign-top"><p class="tableblock">{{ rule.references.cis.controls_v8 | render_rules if rule.references.cis.controls_v8 is not none }}</p></td>
</tr>
{% endif %}
{% if "INDIGO" in baseline.title | upper or show_all_tags %}
<tr>
<th class="tableblock halign-left valign-top"><p class="tableblock">indigo</p></th>
<td class="tableblock halign-left valign-top"><p class="tableblock">{{ rule.references.bsi.indigo | render_rules if rule.references.bsi.indigo is not none }}</p></td>
</tr>
{% endif %}
{% if "CMMC" in baseline.title | upper or show_all_tags %}
<tr>
<th class="tableblock halign-left valign-top"><p class="tableblock">CMMC</p></th>
<td class="tableblock halign-left valign-top"><p class="tableblock">{{ rule.references.disa.cmmc | render_rules if rule.references.disa.cmmc is not none }}</p></td>
</tr>
{% endif %}
{% if rule.references.nist.cce is not none %}
<tr>
<th class="tableblock halign-left valign-top"><p class="tableblock">CCE</p></th>
<td class="tableblock halign-left valign-top"><p class="tableblock">{{ rule.references.nist.cce | render_rules }}</p></td>
</tr>
{% endif %}
{% if custom %}
<tr>
<th class="tableblock halign-left valign-top"><p class="tableblock">Custom References</p></th>
<td class="tableblock halign-left valign-top"><p class="tableblock">{{ rule.references.custom_refs | render_rules if rule.references.cce is not none }}</p></td>
</tr>
{% endif %}
{% if show_all_tags %}
<tr>
<th class="tableblock halign-left valign-top"><p class="tableblock">TAGS</p></th>
<td class="tableblock halign-left valign-top"><p class="tableblock">{{ rule.tags | render_rules }}</p></td>
</tr>
{% endif %}
</tbody>
</table></div></td>
</tr>
</tbody>
</table>
{% endif %}
